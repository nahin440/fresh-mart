# Add your MongoDB URI here
MONGODB_URI=

# Add your ImgBB API key here (from https://api.imgbb.com/)
# Used server-side only by /api/upload — do NOT prefix with NEXT_PUBLIC_,
# that would expose it in the browser bundle.
IMGBB_API_KEY=

# Optional: Public URL for metadata
NEXT_PUBLIC_URL=http://localhost:3000
