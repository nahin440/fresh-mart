# MongoDB Connection URI
# Replace with your MongoDB Atlas URI or local MongoDB URI
# Example: mongodb+srv://user:password@cluster.mongodb.net/freshmart
MONGODB_URI=mongodb://localhost:27017/freshmart

# ImgBB API Key (get one free at https://api.imgbb.com/)
# Used server-side only by /api/upload for the admin product image uploader.
IMGBB_API_KEY=

# Public URL (used for SEO metadata)
NEXT_PUBLIC_URL=http://localhost:3000
